{
  "service": {
    "Name": "report",
    "Id": "report-service",
    "Port": 8080,
    "Tags": ["openlmis-service"],
    "check": {
      "interval": "10s",
      "http": "http://HOST:PORT/actuator/health",
      "timeout": "5s",
      "deregisterCriticalServiceAfter": "10m"
    }
  },
  "raml": "/consul/api-definition.yaml",
  "path": [
    "report",
    "report/docs",
    "report/docs/<all>",
    "report/webjars",
    "report/webjars/<all>"
  ]
}
